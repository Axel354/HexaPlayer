<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.HexaPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple_primary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_purple_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorText</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="Theme.HexaPlayer.DeepPurple" parent="Theme.HexaPlayer">
        <item name="colorPrimary">@color/accent_deep_purple_primary</item>
        <item name="colorSecondary">@color/accent_deep_purple_secondary</item>
    </style>

    <style name="Theme.HexaPlayer.Blue" parent="Theme.HexaPlayer">
        <item name="colorPrimary">@color/accent_blue_primary</item>
        <item name="colorSecondary">@color/accent_blue_secondary</item>
    </style>

    <style name="Theme.HexaPlayer.Teal" parent="Theme.HexaPlayer">
        <item name="colorPrimary">@color/accent_teal_primary</item>
        <item name="colorSecondary">@color/accent_teal_secondary</item>
    </style>

    <style name="Theme.HexaPlayer.Pink" parent="Theme.HexaPlayer">
        <item name="colorPrimary">@color/accent_pink_primary</item>
        <item name="colorSecondary">@color/accent_pink_secondary</item>
    </style>

    <style name="Theme.HexaPlayer.Orange" parent="Theme.HexaPlayer">
        <item name="colorPrimary">@color/accent_orange_primary</item>
        <item name="colorSecondary">@color/accent_orange_secondary</item>
    </style>
</resources>
