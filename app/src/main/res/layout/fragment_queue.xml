<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorSurface">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@color/colorDivider" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_queue_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/queue"
            android:textColor="@color/colorText"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Shuffle note (shown when shuffle is active) -->
    <TextView
        android:id="@+id/tv_shuffle_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/queue_shuffle_note"
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <!-- Queue list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_queue"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty_queue"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="@string/empty_queue"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
