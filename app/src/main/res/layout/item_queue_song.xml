<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Left highlight bar: visible when this is the current song -->
    <View
        android:id="@+id/playing_indicator"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/colorPrimary"
        android:visibility="invisible" />

    <ImageView
        android:id="@+id/iv_album_art"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_note"
        android:background="@drawable/bg_album_rounded"
        android:clipToOutline="true"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorText"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Small music note icon shown when this song is playing -->
    <ImageView
        android:id="@+id/iv_now_playing"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="4dp"
        android:src="@drawable/ic_music_note"
        android:tint="@color/colorPrimary"
        android:contentDescription="@null"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/btn_remove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:tint="@color/colorTextSecondary"
        android:contentDescription="Remove from queue" />

    <ImageView
        android:id="@+id/iv_drag_handle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="4dp"
        android:src="@drawable/ic_drag_handle"
        android:tint="@color/colorTextSecondary"
        android:alpha="0.6"
        android:contentDescription="@null" />

</LinearLayout>
